<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/wishes.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Floating hearts throughout the page -->
    <div class="page-floating-hearts">
        <div class="floating-heart heart-1">💖</div>
        <div class="floating-heart heart-2">❤️</div>
        <div class="floating-heart heart-3">💕</div>
        <div class="floating-heart heart-4">💗</div>
        <div class="floating-heart heart-5">💓</div>
        <div class="floating-heart heart-6">💖</div>
        <div class="floating-heart heart-7">❤️</div>
        <div class="floating-heart heart-8">💕</div>
        <div class="floating-heart heart-9">💗</div>
        <div class="floating-heart heart-10">💓</div>
        <div class="floating-heart heart-11">💖</div>
        <div class="floating-heart heart-12">❤️</div>
        <div class="floating-heart heart-13">💕</div>
        <div class="floating-heart heart-14">💗</div>
        <div class="floating-heart heart-15">💓</div>
    </div>
   
    <div class="con1">
        <h2 class="head1">
            <marquee behavior="scroll" direction="left" scrollamount="20"> 💖 💖 💖 Wish You the Happiest Birthday, Kalla Darshan ❤️🎉🥰 💖 💖 💖</marquee>
        </h2>
    </div>

    <div class="con2">
        <h2 class="head2">
            <marquee behavior="scroll" direction="left" scrollamount="20"> Here are some Sweet Wishes for you Kalla ❤️ 🎉 🥰 </marquee>
        </h2>
    </div>

    <div class="wish">
        <% wishes.forEach(wish=> { %>
            <div class="list">
                <div class="book">
                    <p><%= wish.wish %></p>
                    <div class="cover">
                        <p><%= wish.name %></p>
                    </div>
                </div>
                <div class="bottom"></div>
            </div>
        <% }) %>
    </div>

</body>
</html>